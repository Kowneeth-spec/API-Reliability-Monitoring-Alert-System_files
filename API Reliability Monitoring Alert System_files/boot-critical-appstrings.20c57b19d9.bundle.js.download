"use strict";(globalThis.webpackChunk_ms_uno_app=globalThis.webpackChunk_ms_uno_app||[]).push([[387],{"../resources/lib/resources-strings.json":e=>{e.exports=JSON.parse('{"AddTaskCard_AddTaskPlaceholderText":"Enter a task name * (required)","_AddTaskCard_AddTaskPlaceholderText.comment":"Placeholder text before user enters a task name into the text field. The asterisk and text indicate the field is required for creating a new task","AddTaskCard_TaskNameText":"Task name","_AddTaskCard_TaskNameText.comment":"Label for task name","AddTaskCard_AddTaskButtonText":"Add task","_AddTaskCard_AddTaskButtonText.comment":"[TAG:APPS-Planner-CreateTask] Label for the add task button","AddTaskCard_AddTaskFormAriaLabel":"Add task form","_AddTaskCard_AddTaskFormAriaLabel.comment":"[TAG:APPS-Planner-CreateTask] Aria label for the add task form","AddTaskCard_BucketText":"Set bucket","_AddTaskCard_BucketText.comment":"Label for setting bucket","AddTaskCard_DueDateValueText":"Due {0}","_AddTaskCard_DueDateValueText.comment":"Prefix for due date when it is set on the add task card {0} will be replaced by a date string. eg (Due MM/DD) => Due 11/7 ","AddTaskCard_BucketButtonAriaLabel":"Buckets menu, {0}","_AddTaskCard_BucketButtonAriaLabel.comment":"[TAG:APPS-Planner-CreateTask] Aria label for the bucket button that opens the bucket menu for the add task control, {0} will be replaced with the name of the currently selected bucket","ArchivedPlanView_UpgradedPlanViewTitle":"This plan has been upgraded to premium","_ArchivedPlanView_UpgradedPlanViewTitle.comment":"[TAG:APPS-Planner-ArchivedPlanView] Title for the upgraded plan view that shows instead of the normal plan view","ArchivedPlanView_UpgradedPlanViewDescription":"Open it in the web app to continue editing.","_ArchivedPlanView_UpgradedPlanViewDescription.comment":"[TAG:APPS-Planner-ArchivedPlanView] Description for the upgraded plan view that shows instead of the normal plan view","ArchivedPlanView_ArchivedPlanViewTitle":"This plan has been archived","_ArchivedPlanView_ArchivedPlanViewTitle.comment":"[TAG:APPS-Planner-ArchivedPlanView] Title for the archived plan view that shows instead of the normal plan view","Bucket_NullBucketLabel":"No bucket","_Bucket_NullBucketLabel.comment":"[TAG:APPS-Planner-Bucket] Label for the bucket containing tasks without an assigned bucket or an invalid bucket","Bucket_NullPlanLabel":"No plan","_Bucket_NullPlanLabel.comment":"[TAG:APPS-Planner-Bucket] Label for the bucket containing tasks without an assigned plan or an invalid plan","Bucket_NullBucketLabelForTodo":"Tasks","_Bucket_NullBucketLabelForTodo.comment":"[TAG:APPS-Planner-Bucket] Label for the bucket containing tasks without an assigned bucket or an invalid bucket for todo lists/plans.","Bucket_DefaultBucketLabel":"No bucket","_Bucket_DefaultBucketLabel.comment":"[TAG:APPS-Todo-Bucket] Label for the default bucket for todo lists/plans.","Bucket_NullBucketInfoIconText":"These tasks haven\'t been added to a bucket yet","_Bucket_NullBucketInfoIconText.comment":"[TAG:APPS-Planner-Bucket] Tooltip text to show next the uncategorized bucket column title to give users info about what tasks are in the column.","Charts_DonutChartTitle":"Status","_Charts_DonutChartTitle.comment":"[TAG:APPS-Planner-Charts] Title for the donut chart showing the status of tasks in a plan","Charts_DonutChartAriaLabel":"Status donut chart. {0} tasks left. {1} tasks not started. {2} tasks in progress. {3} tasks late. {4} tasks completed.","_Charts_DonutChartAriaLabel.comment":"[TAG:APPS-Planner-Charts] Aria label for the donut chart showing the status of tasks in a plan. {0} will be replaced with the number of tasks left, {1} with the number of tasks not started, {2} with the number of tasks in progress, {3} with the number of tasks late, and {4} with the number of tasks completed","Charts_TasksPerUserTitle":"Members","_Charts_TasksPerUserTitle.comment":"[TAG:APPS-Planner-Charts] Title for the bar chart showing the number of tasks assigned to each member","Charts_TasksPerUserAriaLabel":"Members bar chart. {0} tasks unassigned.","_Charts_TasksPerUserAriaLabel.comment":"[TAG:APPS-Planner-Charts] Aria label for the bar chart showing the number of tasks assigned to each member. {0} will be replaced with the number of tasks unassigned","Charts_BucketTitle":"Bucket","_Charts_BucketTitle.comment":"[TAG:APPS-Planner-Charts] Title for the bucket chart showing the number of tasks in each bucket","Charts_BucketChartAriaLabel":"Bucket column chart. {0} buckets. {1}. ","_Charts_BucketChartAriaLabel.comment":"[TAG:APPS-Planner-Charts] Aria label for the bucket column chart. {0} will be replaced with the number of buckets, {1} with the number of tasks in each bucket","Charts_BucketBarChartAriaLabel":"Bucket bar chart. {0} buckets. {1}. ","_Charts_BucketBarChartAriaLabel.comment":"[TAG:APPS-Planner-Charts] Aria label for the bucket bar chart. {0} will be replaced with the number of buckets, {1} with the number of tasks in each bucket","Charts_BucketBarChartWithPaginationAriaLabel":"Bucket bar chart. {0} to {1} buckets of total {2} buckets. {3}. ","_Charts_BucketBarChartWithPaginationAriaLabel.comment":"[TAG:APPS-Planner-Charts] Aria label for the bucket bar chart with pagination. {0} will be replaced with the start index of the buckets shown, {1} with the end index of the buckets shown, {2} with the total number of buckets, {3} with the number of tasks in each bucket","Charts_BucketData":"{0} {1} tasks, ","_Charts_BucketData.comment":"[TAG:APPS-Planner-Charts] Data for the bucket chart. {0} will be replaced with the number of tasks in the bucket, {1} with the bucket name","Charts_BarChartPaginationLabel":"{0} of {1}","_Charts_BarChartPaginationLabel.comment":"[TAG:APPS-Planner-Charts] Label for the pagination of the bar chart. {0} will be replaced with the current page of the bar chart, {1} with the total number of pages available","Charts_PriorityChartAriaLabel":"Priority column chart. {0} {1} tasks, {2} {3} tasks, {4} {5} tasks, {6} {7} tasks","_Charts_PriorityChartAriaLabel.comment":"[TAG:APPS-Planner-Charts] Aria label for the priority column chart. {0} will be replaced with the number of high priority tasks, {1} with the high priority label, {2} with the number of medium priority tasks, {3} with the medium priority label, {4} with the number of low priority tasks, {5} with the low priority label, {6} with the number of no priority tasks, {7} with the no priority label","Charts_ShowNextPage":"Show next page","_Charts_ShowNextPage.comment":"[TAG:APPS-Planner-Charts] Button text to show the next page of the chart","Charts_ShowPrevPage":"Show previous page","_Charts_ShowPrevPage.comment":"[TAG:APPS-Planner-Charts] Button text to show the previous page of the chart","Common_ValidatorNumberMessage":"This field must be a number","_Common_ValidatorNumberMessage.comment":"Error message for number field","EditableLabel_EditLabelButtonAriaLabel":"{0}, press enter to edit label name, use left and right arrow keys to remove labels or search for a label to add","_EditableLabel_EditLabelButtonAriaLabel.comment":"[TAG:APPS-Todoweb-EditableLabel]Aria label for the edit label text field. {0} will be replaced with the current label name","EditableLabel_EditLabelTooltipText":"Edit label name for {0}","_EditableLabel_EditLabelTooltipText.comment":"[TAG:APPS-Todoweb-EditableLabel]Tooltip text for the edit label button on an added label. {0} will be replaced with the current label name","EditableLabel_RemoveButtonAriaLabel":"Remove {0}","_EditableLabel_RemoveButtonAriaLabel.comment":"[TAG:APPS-Todoweb-EditableLabel]Aria label for the remove label button. {0} will be replaced with the label text","EditableLabel_EditButtonAriaLabel":"Edit label name","_EditableLabel_EditButtonAriaLabel.comment":"[TAG:APPS-Todoweb-EditableLabel]Aria label for the edit label button","EditableLabel_AddLabelTooltip":"Add label {0}","_EditableLabel_AddLabelTooltip.comment":"[TAG:APPS-Planner-EditableLabel] Tooltip tex