ext ","NPSSurvey_RatingOption1":"1 - Not at all likely","_NPSSurvey_RatingOption1.comment":"[TAG:APPS-OfficeFeedback] Rating option 1 text ","NPSSurvey_RatingOption2":"2","_NPSSurvey_RatingOption2.comment":"[TAG:APPS-OfficeFeedback] Rating option 2 text ","NPSSurvey_RatingOption3":"3","_NPSSurvey_RatingOption3.comment":"[TAG:APPS-OfficeFeedback] Rating option 3 text ","NPSSurvey_RatingOption4":"4","_NPSSurvey_RatingOption4.comment":"[TAG:APPS-OfficeFeedback] Rating option 4 text ","NPSSurvey_RatingOption5":"5 - Extremely likely","_NPSSurvey_RatingOption5.comment":"[TAG:APPS-OfficeFeedback] Rating option 5 text ","NPSSurvey_PromptFollowupQuestion":"Please tell us more. Why did you choose that answer?","_NPSSurvey_PromptFollowupQuestion.comment":"[TAG:APPS-OfficeFeedback] Follow up Question Text in NPS Survey Prompt ","PremiumPlanDowngradeSurvey_PromptTitle":"We\'d love your feedback.","_PremiumPlanDowngradeSurvey_PromptTitle.comment":"[TAG:APPS-OfficeFeedback] Survey prompt title for the premium plan downgrade survey","PremiumPlanDowngradeSurvey_PromptQuestion":"We have just one question about why you downgraded.","_PremiumPlanDowngradeSurvey_PromptQuestion.comment":"[TAG:APPS-OfficeFeedback] Survey prompt question for the premium plan downgrade survey","PremiumPlanDowngradeSurvey_RatingQuestion":"What was your reason for downgrading?","_PremiumPlanDowngradeSurvey_RatingQuestion.comment":"[TAG:APPS-OfficeFeedback] Rating question for the premium plan downgrade survey","PremiumPlanDowngradeSurvey_RatingOption1":"I wanted a simpler experience","_PremiumPlanDowngradeSurvey_RatingOption1.comment":"[TAG:APPS-OfficeFeedback] Premium plan downgrade survey option 1","PremiumPlanDowngradeSurvey_RatingOption2":"I wanted to use different feature","_PremiumPlanDowngradeSurvey_RatingOption2.comment":"[TAG:APPS-OfficeFeedback] Premium plan downgrade option 2","PremiumPlanDowngradeSurvey_RatingOption3":"Me or my team lost a feature","_PremiumPlanDowngradeSurvey_RatingOption3.comment":"[TAG:APPS-OfficeFeedback] Premium plan downgrade option 3","PremiumPlanDowngradeSurvey_RatingOption4":"Other","_PremiumPlanDowngradeSurvey_RatingOption4.comment":"[TAG:APPS-OfficeFeedback] Premium plan downgrade option 4","CopilotFeedback_QuestionTitle":"Select all the issues you noticed with this response","_CopilotFeedback_QuestionTitle.comment":"[TAG:APPS-OfficeFeedback] Question title for the open text question after giving a rating for a copilot generated content","CopilotFeedback_FactuallyIncorrect":"Factually incorrect","_CopilotFeedback_FactuallyIncorrect.comment":"[TAG:APPS-OfficeFeedback] Option for negative feedback on copilot generated content indicating that the content is not factually correct","CopilotFeedback_MissingKeyInformation":"Missing key information","_CopilotFeedback_MissingKeyInformation.comment":"[TAG:APPS-OfficeFeedback]{\\"Ambiguity\\":{\\"Missing\\":\\"lacking or absent\\"}}{\\"Ambiguity\\":{\\"key\\":\\"important or essential\\"}} Option for negative feedback on copilot generated content indicating that the content is lacking important information","CopilotFeedback_NotWhatIAskedFor":"Not what I asked for","_CopilotFeedback_NotWhatIAskedFor.comment":"[TAG:APPS-OfficeFeedback] Option for negative feedback on copilot generated content indicating that the content does not answer the user\'s question or fulfill the user\'s request","CopilotFeedback_UnclearOrHardToUnderstand":"Unclear or hard to understand","_CopilotFeedback_UnclearOrHardToUnderstand.comment":"[TAG:APPS-OfficeFeedback] Option for negative feedback on copilot generated content indicating that the content is difficult to understand or is not clearly written","CopilotFeedback_WasntUseful":"Wasn\'t useful","_CopilotFeedback_WasntUseful.comment":"[TAG:APPS-OfficeFeedback] Option for negative feedback on copilot generated content indicating that the content did not help the user accomplish their task or answer their question","CopilotFeedback_OtherOption":"Other","_CopilotFeedback_OtherOption.comment":"[TAG:APPS-OfficeFeedback]{\\"Ambiguity\\":{\\"Other\\":\\"alternative or unspecified\\"}}Option for feedback on copilot generated content in which user can specify their own feedback","CopilotFeedback_NotWhatINeeded":"Not what I needed","_CopilotFeedback_NotWhatINeeded.comment":"[TAG:APPS-OfficeFeedback] Option for negative feedback on copilot generated content indicating that the content did not meet the user\'s needs in some way, even if it may have been factually correct, clear, or useful in other ways","CopilotFeedback_TooLong":"Too long","_CopilotFeedback_TooLong.comment":"[TAG:APPS-OfficeFeedback] Option for negative feedback on copilot generated content indicating that the content was excessive in length for the user to read or understand easily","Plan_DefaultPlanTitle":"Private tasks","_Plan_DefaultPlanTitle.comment":"Title of the plan where tasks are created by default","Plan_FlaggedEmailPlanTitle":"Flagged emails","_Plan_FlaggedEmailPlanTitle.comment":"Title of the plan where flagged emails are stored","Plan_WordDocumentText":"Word","_Plan_WordDocumentText.comment":"{PlaceHolder=\\"Word\\"}[BRANDING][TAG:APPS-Planner-Plan] Branding name text for Word type document plans","Plan_ExcelDocumentText":"Excel","_Plan_ExcelDocumentText.comment":"{PlaceHolder=\\"Excel\\"}[BRANDING][TAG:APPS-Planner-Plan] Branding name text for Excel type document plans","Plan_PowerPointDocumentText":"PowerPoint","_Plan_PowerPointDocumentText.comment":"{PlaceHolder=\\"PowerPoint\\"}[BRANDING][TAG:APPS-Planner-Plan] Branding name text for PowerPoint type document plans","Open_PlanNameTooltip":"Open {0}","_Open_PlanNameTooltip.comment":"[TAG:Planner-Plan] Tooltip text that opens a plan. {0} is the plan name.","Plan_PlanColumnHeaderText":"Plan","_Plan_PlanColumnHeaderText.comment":"[TAG:Planner-Plan] Column header text describing plan column in Assigned to me page\'s Grid view.","Plan_FormerPlanName":"Former plan","_Plan_FormerPlanName.comment":"[TAG:Planner-t